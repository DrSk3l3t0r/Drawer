classDiagram
    class DrawerMeasurement {
        +Double widthInches
        +Double depthInches
        +Double heightInches
        +MeasurementSource source
        +Double confidenceScore
        +Bool heightMeasured
        +NormalizedQuad? capturedQuad
        +Array~DrawerObstacle~ obstacles
    }

    class DrawerObstacle {
        +UUID id
        +String name
        +Double x, y, width, height
        +overlaps(rect) Bool
    }

    class MeasurementSource {
        <<enum>>
        lidar
        cameraReference
        cameraEstimate
        manual
        defaultEstimate
    }

    class NormalizedQuad {
        +NormalizedPoint topLeft
        +NormalizedPoint topRight
        +NormalizedPoint bottomLeft
        +NormalizedPoint bottomRight
    }

    class DrawerPurpose {
        <<enum>>
        utensils
        junkDrawer
        spices
        bakingTools
        officeSupplies
        linens
        custom
    }

    class OrganizerTemplate {
        +String id
        +String name
        +Double width
        +Double height
        +Double hue
        +Int priority
        +String group
        +Int groupOrder
    }

    class UserDefinedTemplate {
        +UUID id
        +String name
        +Double widthInches, heightInches
        +Double hue
        +Date date
    }

    class OrganizerItem {
        +UUID id
        +String name
        +Double x, y, width, height
        +Double colorHue, colorSaturation, colorBrightness
        +Int tier
        +UUID? stacksOn
    }

    class DrawerLayout {
        +DrawerMeasurement measurement
        +DrawerPurpose purpose
        +Array~OrganizerItem~ items
        +Double coveragePercentage
        +Array~String~ unplacedTemplates
        +Array~String~ warnings
        +Array~String~ selectedTemplateIds
    }

    class SavedDrawer {
        +UUID id
        +String name
        +Date date
        +DrawerLayout layout
        +Data? photoData
    }

    class KitchenPlan {
        +UUID id
        +String name
        +Date date
        +Array~Entry~ drawerEntries
    }

    class KitchenPlanEntry {
        +UUID id
        +UUID drawerId
        +String location
        +Int order
    }

    class PrintableModule {
        +UUID id
        +Double outerWidthMm, outerDepthMm, heightMm
        +Double originXMm, originYMm
        +Double wallThicknessMm
        +String tintHex
        +Int tier
        +Double zOffsetMm
        +Int? splitPartIndex
        +Int? splitPartCount
        +UUID? originalModuleId
        +Bool isLocatingLip
    }

    class PrintableOrganizer {
        +Array~PrintableModule~ modules
        +Double drawerInteriorWidthMm
        +Double drawerInteriorDepthMm
        +PrintSettings settings
        +FilamentProfile filament
        +PrinterProfile printer
        +DrawerPurpose purpose
    }

    class PrintSettings {
        +Double layerHeightMm
        +Double wallThicknessMm
        +Double bottomThicknessMm
        +Double toleranceMm
        +Double heightMm
        +Double infillPercent
        +Bool autoSplitOversized
        +Double tier2HeightMm
    }

    class AMSLitePlate {
        +Array~FilamentProfile?~ slots
    }

    class AMSLiteAssignment {
        +Int defaultSlot
        +Dictionary moduleSlot
        +Dictionary featureSlot
        +Dictionary moduleFeatureSlot
    }

    class FilamentProfile {
        +FilamentMaterial material
        +FilamentColor color
    }

    class PrintActivityAttributes {
        +String drawerName
        +String printerName
        +Double totalGrams
        +Int totalSeconds
    }

    class ContentState {
        +Double progress
        +Int remainingSeconds
        +String statusLabel
        +Bool isComplete
    }

    class DrawerStore {
        +Array~SavedDrawer~ savedDrawers
        +Array~UserDefinedTemplate~ userTemplates
        +Array~KitchenPlan~ kitchenPlans
        +Double costPerKg
    }

    DrawerMeasurement --> MeasurementSource
    DrawerMeasurement --> NormalizedQuad
    DrawerMeasurement --> DrawerObstacle
    DrawerLayout --> DrawerMeasurement
    DrawerLayout --> DrawerPurpose
    DrawerLayout --> OrganizerItem
    SavedDrawer --> DrawerLayout
    KitchenPlan --> KitchenPlanEntry
    KitchenPlanEntry --> SavedDrawer : refs by id
    OrganizerTemplate --> DrawerPurpose : grouped by
    PrintableOrganizer --> PrintableModule
    PrintableOrganizer --> DrawerPurpose
    PrintableOrganizer --> PrintSettings
    AMSLitePlate --> FilamentProfile
    AMSLiteAssignment --> AMSLitePlate
    PrintActivityAttributes --> ContentState : has
    DrawerStore --> SavedDrawer
    DrawerStore --> UserDefinedTemplate
    DrawerStore --> KitchenPlan
